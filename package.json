{
  "name": "astro-antfustyle-theme",
  "version": "3.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "astro": "astro",
    "sync": "astro sync",
    "dev": "astro dev",
    "check": "astro check",
    "build": "astro build",
    "preview": "astro preview",
    "format": "prettier . --check --ignore-unknown",
    "format:write": "prettier . --write --ignore-unknown --cache",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0 --cache",
    "lint:fix": "eslint . --fix --cache",
    "toolbar:on": "astro preferences enable devToolbar",
    "toolbar:off": "astro preferences disable devToolbar",
    "prepare": "simple-git-hooks",
    "postbuild": "pagefind --site dist --exclude-selectors \"pre\" --include-characters \"<>\" && del-cli \"dist/pagefind/*ui*\""
  },
  "devDependencies": {
    "@ascorbic/feed-loader": "^2.0.1",
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@atproto/api": "^0.20.25",
    "@eslint/js": "^9.39.4",
    "@expressive-code/plugin-collapsible-sections": "^0.44.0",
    "@expressive-code/plugin-line-numbers": "^0.44.0",
    "@iconify/json": "^2.2.496",
    "@types/node": "^24.13.2",
    "@types/nprogress": "^0.2.3",
    "@types/p5": "^1.7.7",
    "@typescript-eslint/parser": "^8.62.1",
    "@unocss/astro": "^66.7.4",
    "@unocss/reset": "^66.7.4",
    "astro": "^7.0.7",
    "astro-expressive-code": "^0.44.0",
    "astro-loader-bluesky-posts": "^1.2.5",
    "astro-loader-github-prs": "^2.0.1",
    "astro-loader-github-releases": "^3.0.1",
    "astro-robots-txt": "^1.0.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^16.5.0",
    "html-entities": "^2.6.0",
    "lint-staged": "^17.0.8",
    "mdast-util-to-string": "^4.0.0",
    "nprogress": "^0.2.0",
    "p5": "^1.11.13",
    "pagefind": "^1.5.2",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-callouts": "^2.2.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-wrap-all": "^1.1.0",
    "remark-directive": "^4.0.0",
    "remark-directive-sugar": "^2.0.1",
    "remark-imgattr": "^1.1.1",
    "remark-math": "^6.0.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.35.3",
    "simple-git-hooks": "2.13.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "unist-util-visit": "^5.1.0",
    "unocss": "^66.7.4",
    "viewerjs": "^1.11.7"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": [
      "eslint"
    ]
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
